//@version=6
indicator(title="CRT Pattern Detector", shorttitle="CRT Det", overlay=true, format=format.price, precision=2)

// ─── Inputs ────────────────────────────────────────────────────────────────
swingLen      = input.int(5,    "Swing Length",          minval=2, maxval=20)
minBodyRatio  = input.float(1.5,"Min Model-1 Body Ratio", minval=0.5, step=0.1)
oteFibLow     = input.float(0.60,"OTE Fib Low",           minval=0.0, step=0.05)
oteFibHigh    = input.float(0.75,"OTE Fib High",          minval=0.0, step=0.05)
showCRT       = input.bool(true, "Show CRT Ranges")
showTS        = input.bool(true, "Show Turtle Soup")
showM1        = input.bool(true, "Show Model-1")
showBreaker   = input.bool(true, "Show Breaker Blocks")
showOTE       = input.bool(true, "Show OTE Zones")
showKOD       = input.bool(true, "Show KOD")
showTradeLvls = input.bool(true, "Show Entry/SL/TP")
alertOnSignal = input.bool(true, "Alert on New Signal")

// ─── Candle Body Utility ────────────────────────────────────────────────────
bodySize     = math.abs(close - open)
bodyHigh     = math.max(close, open)
bodyLow      = math.min(close, open)
totalRange   = high - low
bodyRatio    = bodySize / (totalRange > 0 ? totalRange : 1)
isThickBull  = close > open and bodyRatio >= 0.6
isThickBear  = open > close and bodyRatio >= 0.6
isThick      = isThickBull or isThickBear
atrVal       = ta.atr(14)

// ─── Swing Highs / Lows ─────────────────────────────────────────────────────
swingHigh = ta.pivothigh(high, swingLen, swingLen)
swingLow  = ta.pivotlow(low,   swingLen, swingLen)

// ─── Swing Levels ──────────────────────────────────────────────────────────
lookback     = swingLen * 4
prevHigh     = ta.valuewhen(not na(swingHigh), swingHigh, 1)
prevLow      = ta.valuewhen(not na(swingLow),  swingLow,  1)

// ─── Turtle Soup Detection ─────────────────────────────────────────────────
tsLowSweep   = low  <= prevLow  and close > prevLow
tsHighSweep  = high >= prevHigh and close < prevHigh
tsDirection  = tsLowSweep ? 1 : tsHighSweep ? -1 : 0

// ─── CRT 3-Candle Range Detection ──────────────────────────────────────────
candle2Sweep = (high[1] > high[2] and close[1] < high[2]) or (low[1] < low[2] and close[1] > low[2])
candle3Exp   = (close > high[1] and high[1] < high[2]) or (close < low[1] and low[1] > low[2])
candle3Dir   = (close > high[1] and high[1] < high[2]) ? 1 : (close < low[1] and low[1] > low[2]) ? -1 : 0
crtPattern   = candle2Sweep and candle3Exp
crtDir       = candle3Dir

// ─── Model-1 Detection ─────────────────────────────────────────────────────
m1SweepHigh  = high >= prevHigh and close <= bodyLow
m1SweepLow   = low  <= prevLow  and close >= bodyHigh
m1Sweep      = m1SweepHigh or m1SweepLow
m1Thick      = isThick and bodyRatio >= minBodyRatio
model1Candle = m1Thick and m1Sweep
m1Direction  = m1SweepLow ? 1 : m1SweepHigh ? -1 : 0

m1Confirmed  = model1Candle and (
    (m1Direction ==  1 and close > high[1]) or
    (m1Direction == -1 and close < low[1])
)

// ─── OTE Zone (Fibonacci 60-75%) ────────────────────────────────────────────
var float oteLow  = na
var float oteHigh = na
if not na(prevHigh) and not na(prevLow)
    range_  = prevHigh - prevLow
    oteLow  := prevLow  + range_ * oteFibLow
    oteHigh := prevLow  + range_ * oteFibHigh

// ─── KOD (Kiss of Death) Detection ──────────────────────────────────────────
kodSweep     = (tsDirection == 1 or tsDirection == -1) and (ta.barssince(not na(swingHigh)) < swingLen * 2 or ta.barssince(not na(swingLow)) < swingLen * 2)
kodNearOTE   = not na(oteLow) and (
    (tsDirection ==  1 and low  >= oteLow  and low  <= oteHigh) or
    (tsDirection == -1 and high <= oteHigh and high >= oteLow)
)
kissOfDeath  = kodSweep and kodNearOTE

// ─── Breaker Block Detection ────────────────────────────────────────────────
breakerCandle = model1Candle[1] and (
    (m1Direction[1] ==  1 and low  <= low[1]  and close > low[1]) or
    (m1Direction[1] == -1 and high >= high[1] and close < high[1])
)
breakerDir    = m1Direction[1]

// ─── Visual Markers ────────────────────────────────────────────────────────
plotshape(showCRT and not na(swingHigh), "Swing High", shape.triangledown, location.abovebar, color.orange, size=size.tiny)
plotshape(showCRT and not na(swingLow),  "Swing Low",  shape.triangleup,   location.belowbar, color.orange, size=size.tiny)

plotshape(showCRT and crtPattern and crtDir == 1, "CRT Bull", shape.arrowup,   location.belowbar, color.blue,  size=size.normal)
plotshape(showCRT and crtPattern and crtDir == -1,"CRT Bear", shape.arrowdown, location.abovebar, color.blue,  size=size.normal)

plotshape(showTS and tsLowSweep,  "TS Bull", shape.diamond, location.belowbar, color.green, size=size.small)
plotshape(showTS and tsHighSweep, "TS Bear", shape.diamond, location.abovebar, color.red,   size=size.small)

plotshape(showM1 and model1Candle and m1Direction == 1, "M1 Bull", shape.square, location.belowbar, color.lime, size=size.small)
plotshape(showM1 and model1Candle and m1Direction == -1,"M1 Bear", shape.square, location.abovebar, color.maroon, size=size.small)

plotshape(showBreaker and breakerCandle and breakerDir == 1, "Brk Bull", shape.cross, location.belowbar, color.teal,  size=size.tiny)
plotshape(showBreaker and breakerCandle and breakerDir == -1,"Brk Bear", shape.cross, location.abovebar, color.purple, size=size.tiny)

plotshape(showKOD and kissOfDeath and tsDirection == 1, "KOD Bull", shape.xcross, location.belowbar, color.yellow, size=size.small)
plotshape(showKOD and kissOfDeath and tsDirection == -1,"KOD Bear", shape.xcross, location.abovebar, color.yellow, size=size.small)

// ─── OTE Zone Box ───────────────────────────────────────────────────────────
var box oteBox = na
if showOTE and not na(oteLow) and not na(oteHigh)
    box.delete(oteBox)
    oteBox := box.new(bar_index - lookback, oteHigh, bar_index, oteLow,
      bgcolor=color.new(color.aqua, 90),
      border_color=color.new(color.aqua, 70),
      border_width=1, text="OTE")

// ─── Trade Level Drawing (inlined — no function to avoid v6 restrictions) ───
slHalf = atrVal * 0.5

// Model-1 confirmed
if showM1 and m1Confirmed and showTradeLvls
    e_ = m1Direction == 1 ? low[1] : high[1]
    s_ = m1Direction == 1 ? low[1] - slHalf : high[1] + slHalf
    r_ = math.abs(e_ - s_)
    t1 = m1Direction == 1 ? e_ + r_ * 1.5 : e_ - r_ * 1.5
    t2 = m1Direction == 1 ? e_ + r_ * 2.0 : e_ - r_ * 2.0
    lc = m1Direction == 1 ? color.lime : color.red
    line.new(bar_index - 1, e_, bar_index + 2, e_, color=lc, width=1, style=line.style_dashed, extend=extend.right)
    line.new(bar_index - 1, s_, bar_index + 2, s_, color=color.new(color.red, 30), width=1, style=line.style_dashed, extend=extend.right)
    line.new(bar_index - 1, t1, bar_index + 2, t1, color=color.new(color.green, 40), width=1, style=line.style_dotted, extend=extend.right)
    line.new(bar_index - 1, t2, bar_index + 2, t2, color=color.new(color.lime, 30), width=1, style=line.style_dotted, extend=extend.right)
    label.new(bar_index - 1, high + atrVal * 0.5, m1Direction == 1 ? "M1 LONG" : "M1 SHORT", color=lc, style=label.style_label_down, textcolor=color.white, size=size.small)

// CRT pattern
if showCRT and crtPattern and showTradeLvls
    e_ = crtDir == 1 ? low[2] : high[2]
    s_ = crtDir == 1 ? low[2] - slHalf : high[2] + slHalf
    r_ = math.abs(e_ - s_)
    t1 = crtDir == 1 ? e_ + r_ * 1.5 : e_ - r_ * 1.5
    t2 = crtDir == 1 ? e_ + r_ * 2.0 : e_ - r_ * 2.0
    lc = crtDir == 1 ? color.blue : color.orange
    line.new(bar_index, e_, bar_index + 2, e_, color=lc, width=1, style=line.style_dashed, extend=extend.right)
    line.new(bar_index, s_, bar_index + 2, s_, color=color.new(color.red, 30), width=1, style=line.style_dashed, extend=extend.right)
    line.new(bar_index, t1, bar_index + 2, t1, color=color.new(color.green, 40), width=1, style=line.style_dotted, extend=extend.right)
    line.new(bar_index, t2, bar_index + 2, t2, color=color.new(color.lime, 30), width=1, style=line.style_dotted, extend=extend.right)
    label.new(bar_index, high + atrVal * 0.5, crtDir == 1 ? "CRT LONG" : "CRT SHORT", color=lc, style=label.style_label_down, textcolor=color.white, size=size.small)

// Breaker
if showBreaker and breakerCandle and showTradeLvls
    e_ = breakerDir == 1 ? bodyLow[1] : bodyHigh[1]
    s_ = breakerDir == 1 ? low[1] - slHalf : high[1] + slHalf
    r_ = math.abs(e_ - s_)
    t1 = breakerDir == 1 ? e_ + r_ * 1.5 : e_ - r_ * 1.5
    t2 = breakerDir == 1 ? e_ + r_ * 2.0 : e_ - r_ * 2.0
    lc = breakerDir == 1 ? color.teal : color.purple
    line.new(bar_index - 1, e_, bar_index + 2, e_, color=lc, width=1, style=line.style_dashed, extend=extend.right)
    line.new(bar_index - 1, s_, bar_index + 2, s_, color=color.new(color.red, 30), width=1, style=line.style_dashed, extend=extend.right)
    line.new(bar_index - 1, t1, bar_index + 2, t1, color=color.new(color.green, 40), width=1, style=line.style_dotted, extend=extend.right)
    line.new(bar_index - 1, t2, bar_index + 2, t2, color=color.new(color.lime, 30), width=1, style=line.style_dotted, extend=extend.right)
    label.new(bar_index - 1, high + atrVal * 0.5, breakerDir == 1 ? "BRK LONG" : "BRK SHORT", color=lc, style=label.style_label_down, textcolor=color.white, size=size.small)

// ─── Table Info ─────────────────────────────────────────────────────────────
var table infoTbl = table.new(position.bottom_right, 2, 1, bgcolor=color.new(color.black, 80), frame_color=color.gray)
if barstate.islast
    table.cell(infoTbl, 0, 0, "CRT Det v1 | Swing " + str.tostring(swingLen), textcolor=color.gray, text_size=size.tiny)

// ─── Alerts ─────────────────────────────────────────────────────────────────
if alertOnSignal and (crtPattern or m1Confirmed or breakerCandle or kissOfDeath)
    msg = ""
    if crtPattern       and crtDir == 1          ; msg += "CRT BULL "
    if crtPattern       and crtDir == -1         ; msg += "CRT BEAR "
    if m1Confirmed      and m1Direction == 1     ; msg += "| M1 BULL "
    if m1Confirmed      and m1Direction == -1    ; msg += "| M1 BEAR "
    if breakerCandle    and breakerDir == 1      ; msg += "| BRK BULL "
    if breakerCandle    and breakerDir == -1     ; msg += "| BRK BEAR "
    if kissOfDeath      and tsDirection == 1     ; msg += "| KOD BULL "
    if kissOfDeath      and tsDirection == -1    ; msg += "| KOD BEAR "
    alert("CRT Signal: " + msg, alert.freq_once_per_bar)

plot(na, "Debug", display=display.none)
