# Exchange config
EXCHANGE_ID=kucoin
SYMBOL=BTC/USDT
ENTRY_MODE=limit_retest
USE_LTF=false

# Capital & risk
INITIAL_CAPITAL=10000
RISK_PER_TRADE=0.02
FEE_RATE=0.0004
STOP_LOSS_PCT=0.02
TP1=1.5
TP2=2.0
ENTRY_LOGIC=extreme

# Interval (seconds)
POLL_INTERVAL=60

# PostgreSQL (set by Render automatically)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
